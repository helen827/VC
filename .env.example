## LLM (OpenAI-compatible) configuration
#
# Recommended: use an OpenAI-compatible endpoint you can access in China.
# The app only needs Chat Completions: POST /chat/completions
#
# Examples:
# - Qiniu AI inference (OpenAI compatible):
#   LLM_BASE_URL="https://api.qnaigc.com/v1"
#   LLM_API_KEY="YOUR_QINIU_BEARER_TOKEN"
#
# - DeepSeek / Qwen compatible endpoints:
#   LLM_BASE_URL="https://<your-endpoint>/v1"
#   LLM_API_KEY="YOUR_API_KEY"
#
LLM_BASE_URL="https://api.qnaigc.com/v1"
## 推荐配置：填七牛「AI 大模型推理」的 API Key（Bearer，通常 sk- 开头）
LLM_API_KEY=""
##
## 兼容配置：如果你已在其他项目使用七牛并配置了 QINIU_AI_API_KEY（如 MeetingPilot），
## 也可以不填 LLM_API_KEY，本工具会自动读取 QINIU_AI_API_KEY 作为 Bearer key。
QINIU_AI_API_KEY=""
LLM_MODEL="deepseek-v3"

## Optional: HTTP fetching
FETCH_TIMEOUT_MS="15000"
FETCH_CONCURRENCY="4"

## Server
PORT="3417"

## Public deployment access control (recommended)
## If set, the website/API requires this password.
ACCESS_TOKEN=""

