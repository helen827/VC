{
  "name": "geo-agent-web",
  "version": "0.1.0",
  "private": true,
  "description": "Local web app to generate GEO content/eval packs for any company (China-focused LLM discovery).",
  "type": "module",
  "scripts": {
    "dev": "npm run build && npm run start",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jszip": "^3.10.1",
    "mammoth": "^1.7.2",
    "multer": "^2.1.1",
    "nanoid": "^5.0.7",
    "p-limit": "^6.1.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
